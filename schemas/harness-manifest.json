{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/KwokJay/cc-agent-harness/schemas/harness-manifest.json",
  "title": "HarnessManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestVersion",
    "generatedAt",
    "harnessCliVersion",
    "project",
    "tools",
    "toolpacks",
    "skills",
    "verification",
    "generatedFilesCount"
  ],
  "properties": {
    "manifestVersion": {
      "type": "integer",
      "minimum": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "harnessCliVersion": {
      "type": "string"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "language"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "language": { "type": "string" },
        "framework": { "type": "string" }
      }
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "toolpacks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "packSource", "packVersion"],
        "properties": {
          "id": { "type": "string" },
          "packSource": { "type": "string" },
          "packVersion": { "type": "string" },
          "provenance": { "type": "string", "enum": ["official", "community"] },
          "verificationHint": { "type": "string" },
          "sharedPolicy": { "type": "boolean" }
        }
      }
    },
    "skills": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count", "ids"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checks"],
      "properties": {
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "command"],
            "properties": {
              "name": { "type": "string" },
              "command": { "type": "string" }
            }
          }
        }
      }
    },
    "generatedFilesCount": {
      "type": "integer",
      "minimum": 0
    },
    "adoption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "toolsEnabled",
        "toolpacksEnabled",
        "officialToolpacksEnabled",
        "skillsDiscovered",
        "verificationChecksConfigured"
      ],
      "properties": {
        "toolsEnabled": { "type": "integer", "minimum": 0 },
        "toolpacksEnabled": { "type": "integer", "minimum": 0 },
        "officialToolpacksEnabled": { "type": "integer", "minimum": 0 },
        "skillsDiscovered": { "type": "integer", "minimum": 0 },
        "verificationChecksConfigured": { "type": "integer", "minimum": 0 }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "daysSinceLastVerify",
        "generatedFilesTracked",
        "generatedFilesPresentOnDisk",
        "artifactCoverageRatio"
      ],
      "properties": {
        "lastVerifyAt": { "type": "string", "format": "date-time" },
        "lastVerifyOk": { "type": "boolean" },
        "daysSinceLastVerify": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "generatedFilesTracked": { "type": "integer", "minimum": 0 },
        "generatedFilesPresentOnDisk": { "type": "integer", "minimum": 0 },
        "artifactCoverageRatio": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "aggregation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "org": { "type": "string" },
        "repo_slug": { "type": "string" }
      }
    },
    "approved_exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "target": { "type": "string" }
        }
      }
    }
  }
}
