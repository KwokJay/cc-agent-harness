{
  "name": "cc-agent-harness",
  "version": "0.0.1",
  "description": "Universal development pipeline harness — configuration, templates, skill management, and health checks for AI-assisted projects.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KwokJay/cc-agent-harness.git"
  },
  "homepage": "https://github.com/KwokJay/cc-agent-harness#readme",
  "bugs": {
    "url": "https://github.com/KwokJay/cc-agent-harness/issues"
  },
  "keywords": [
    "agent",
    "harness",
    "cli",
    "ai",
    "workflow",
    "context-engineering",
    "developer-tools"
  ],
  "bin": {
    "agent-harness": "./dist/bin/harness.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.1.0"
  }
}
