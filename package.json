{
  "name": "cc-agent-harness",
  "version": "0.7.0",
  "description": "Harness scaffold tool — initialize AI-assisted development environments for any project type and AI coding tool.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KwokJay/cc-agent-harness.git"
  },
  "homepage": "https://github.com/KwokJay/cc-agent-harness#readme",
  "bugs": {
    "url": "https://github.com/KwokJay/cc-agent-harness/issues"
  },
  "keywords": [
    "agent",
    "harness",
    "scaffold",
    "cli",
    "ai",
    "cursor",
    "claude-code",
    "copilot",
    "codex",
    "opencode",
    "context-engineering",
    "developer-tools"
  ],
  "bin": {
    "harn": "./dist/harness.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "schemas",
    "docs"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "verify": "pnpm lint && pnpm test && pnpm build && pnpm test:e2e && pnpm check:toolpack-index",
    "agent-review": "pnpm lint && pnpm test:coverage && pnpm build && pnpm test:e2e && pnpm check:toolpack-index",
    "generate:toolpack-index": "pnpm build && node scripts/generate-toolpack-index.mjs",
    "check:toolpack-index": "node scripts/generate-toolpack-index.mjs --check",
    "changeset": "changeset",
    "prepublishOnly": "pnpm verify"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "commander": "^13.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.1.0"
  }
}
